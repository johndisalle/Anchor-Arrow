rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User documents: only the owner can read/write
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /driftLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Circles: members only (except create)
    match /circles/{circleId} {
      // Anyone can create a circle; only members can read/update
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.memberIds;
      // Members can update (post, join via code adds to memberIds)
      allow update: if request.auth != null &&
                      (request.auth.uid in resource.data.memberIds ||
                       request.resource.data.memberIds.hasAll(resource.data.memberIds));
      // Only creator can delete the circle
      allow delete: if request.auth != null &&
                      resource.data.creatorId == request.auth.uid;

      match /posts/{postId} {
        // Only circle members can read posts
        allow read: if request.auth != null &&
                       get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
        // Only circle members can create posts
        allow create: if request.auth != null &&
                         get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
        // Author or circle creator can update/delete
        allow update: if request.auth != null &&
                         (resource.data.authorId == request.auth.uid ||
                          get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid);
        allow delete: if request.auth != null &&
                         (resource.data.authorId == request.auth.uid ||
                          get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid);

        match /comments/{commentId} {
          allow read: if request.auth != null &&
                         get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
          allow create: if request.auth != null &&
                           get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
          allow delete: if request.auth != null &&
                           (resource.data.authorId == request.auth.uid ||
                            get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid);
        }
      }
    }

    // Reports: anyone can create, only admins can read
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false; // Admin reads via Cloud Functions
    }
  }
}
