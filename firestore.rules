rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isCircleMember(circleId) {
      let circle = get(/databases/$(database)/documents/circles/$(circleId));
      return isAuthenticated() && request.auth.uid in circle.data.memberIds;
    }

    function isCirclePublic(circleId) {
      let circle = get(/databases/$(database)/documents/circles/$(circleId));
      return circle.data.isPublic == true;
    }

    // ─── Users ──────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read and write their own document.
      // Any authenticated user can read other users' profiles
      // (needed for circle member names, streaks, battle formation).
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // Daily entries subcollection
      match /entries/{entryId} {
        allow read, write: if isOwner(userId);
      }

      // Drift logs subcollection
      match /driftLogs/{logId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Circles ────────────────────────────────────────────────
    match /circles/{circleId} {

      // Any authenticated user can read public circles (for browse).
      // Private circles can only be read by members.
      allow read: if isAuthenticated() &&
        (resource.data.isPublic == true || request.auth.uid in resource.data.memberIds);

      // Any authenticated user can create a circle
      allow create: if isAuthenticated() &&
        request.resource.data.creatorId == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds;

      // Members can update (join/leave updates memberIds).
      // Only allow memberIds changes, not name/creator hijacking.
      allow update: if isAuthenticated() && (
        // Existing members can update
        request.auth.uid in resource.data.memberIds ||
        // New members can join public circles
        (resource.data.isPublic == true && request.auth.uid in request.resource.data.memberIds)
      );

      // Only the creator can delete a circle
      allow delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;

      // ─── Circle Posts ───────────────────────────────────────
      match /posts/{postId} {
        // Members can read posts. Public circle posts readable by any authenticated user.
        allow read: if isAuthenticated() &&
          (isCirclePublic(circleId) || isCircleMember(circleId));

        // Only members can create posts
        allow create: if isCircleMember(circleId) &&
          request.resource.data.authorId == request.auth.uid;

        // Members can update posts (reactions, pin, mark answered)
        allow update: if isCircleMember(circleId);

        // Author or circle creator can delete posts
        allow delete: if isCircleMember(circleId) &&
          (resource.data.authorId == request.auth.uid ||
           get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid);

        // ─── Comments ───────────────────────────────────────
        match /comments/{commentId} {
          allow read: if isAuthenticated() &&
            (isCirclePublic(circleId) || isCircleMember(circleId));

          allow create: if isCircleMember(circleId) &&
            request.resource.data.authorId == request.auth.uid;

          // Author can update/delete own comments; circle creator can also delete any comment
          allow update: if isCircleMember(circleId) &&
            resource.data.authorId == request.auth.uid;
          allow delete: if isCircleMember(circleId) &&
            (resource.data.authorId == request.auth.uid ||
             get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid);
        }
      }
    }

    // ─── Reports ──────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if isAuthenticated();
    }
  }
}
