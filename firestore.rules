rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User documents: owner or admin can read; only owner can write
    match /users/{uid} {
      allow read: if request.auth != null &&
                     (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
      // Admin can update any user (toggle premium, admin status)
      allow update: if isAdmin();

      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /driftLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Circles: members can read/update; admin can read/update/delete any
    match /circles/{circleId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null &&
                     (request.auth.uid in resource.data.memberIds || isAdmin());
      allow update: if request.auth != null &&
                      (request.auth.uid in resource.data.memberIds ||
                       request.resource.data.memberIds.hasAll(resource.data.memberIds) ||
                       isAdmin());
      allow delete: if request.auth != null &&
                      (resource.data.creatorId == request.auth.uid || isAdmin());

      match /posts/{postId} {
        allow read: if request.auth != null &&
                       (get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]) ||
                        isAdmin());
        allow create: if request.auth != null &&
                         get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
        allow update, delete: if request.auth != null &&
                         (resource.data.authorId == request.auth.uid ||
                          get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid ||
                          isAdmin());

        match /comments/{commentId} {
          allow read: if request.auth != null &&
                         (get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]) ||
                          isAdmin());
          allow create: if request.auth != null &&
                           get(/databases/$(database)/documents/circles/$(circleId)).data.memberIds.hasAny([request.auth.uid]);
          allow delete: if request.auth != null &&
                           (resource.data.authorId == request.auth.uid ||
                            get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid ||
                            isAdmin());
        }
      }
    }

    // Reports: anyone can create; only admins can read/update
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }
  }
}
